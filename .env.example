# =============================================================================
#  Variables d'environnement des Edge Functions (Stripe).
#  À renseigner dans Supabase : `supabase secrets set --env-file ./.env`
#  Ne JAMAIS committer le vrai .env (voir .gitignore).
# =============================================================================

# --- Supabase (auto-injectées en prod, à renseigner pour le dev local) ---
SUPABASE_URL=https://VOTRE-PROJET.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...   # SECRET — jamais côté front

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...                   # donné par `stripe listen` / dashboard

# --- Price IDs des 3 plans SaaS PairForm (créés dans Stripe > Produits) ---
STRIPE_PRICE_COACH=price_...                       # Phase 1 — abonnement coach
STRIPE_PRICE_ATHLETE=price_...                     # Phase 3 — abonnement athlète B2C
STRIPE_PRICE_CLUB=price_...                        # Phase 2 — abonnement club

# --- Formules CLUB vendues aux adhérents (Stripe Connect) ---
# Pas de Price ID : les tarifs (dropin/sub/coach) sont édités par chaque club
# et envoyés en price_data dynamique. Connect requis pour que le club encaisse.
PLATFORM_FEE_PERCENT=0                              # commission plateforme sur les ventes club (%)
STRIPE_CONNECT_COUNTRY=FR                           # pays des comptes connectés Express

# --- URL de retour après paiement / OAuth (front) ---
APP_URL=http://localhost:5500

# =============================================================================
#  OBJETS CONNECTÉS (synchronisation des activités)
# =============================================================================

# --- Strava (API publique : https://www.strava.com/settings/api) ---
#  « Authorization Callback Domain » à régler dans l'app Strava sur le domaine
#  de tes edge functions, ex: VOTRE-PROJET.supabase.co
STRAVA_CLIENT_ID=12345
STRAVA_CLIENT_SECRET=...                            # SECRET
STRAVA_VERIFY_TOKEN=pairform-strava                 # choisi par toi (souscription webhook)

# --- Garmin (Garmin Connect Developer Program — homologation requise) ---
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=

# --- Coros (COROS Open API — accès partenaire requis) ---
COROS_CLIENT_ID=
COROS_CLIENT_SECRET=

# =============================================================================
#  EMAILS TRANSACTIONNELS (invitations) — Resend (https://resend.com)
# =============================================================================
RESEND_API_KEY=re_...                               # si absent : l'invite renvoie juste le lien
RESEND_FROM=PairForm <invite@VOTRE-DOMAINE>         # domaine vérifié dans Resend

# =============================================================================
#  ASSISTANT IA — add-on coach (option payante ~12 €/mois) · cf. PAIRFORM-AI-ADDON-PLAN.md
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...                         # clé API Claude
ANTHROPIC_MODEL=claude-sonnet-4-6                    # défaut ; claude-haiku-4-5 pour le volume
AI_ADDON_PRICE_EUR=12                                # prix add-on si pas de Price fixe
STRIPE_PRICE_AI=                                     # optionnel : Price ID Stripe dédié (sinon price_data dynamique)
